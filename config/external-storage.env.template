# External Storage Configuration Template
# Copy this to your .env file and modify the path to match your external drive
# 
# This configures Theseus Insight to store all data on an external drive

# Path to your external storage location
EXTERNAL_DATA_PATH=/Volumes/nyx/theseus_insight_data

# Examples for different operating systems:
# macOS external drive:    /Volumes/your_drive_name/theseus_insight_data
# Linux external drive:    /mnt/external_drive/theseus_insight_data
# Windows external drive:  D:\theseus_insight_data

# All your other environment variables should also be included in your .env file:
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# GMAIL_SENDER_ADDRESS=your_email@gmail.com
# GMAIL_APP_PASSWORD=your_app_password
# DATABASE_URL=postgresql://theseus:theseus@db:5432/theseusdb
# etc... 