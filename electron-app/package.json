{
  "name": "theseus-desktop",
  "version": "0.9.4",
  "main": "main.js",
  "description": "Electron wrapper for Theseus Insight",
  "author": "Theseus Insight Team",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "node build-app-turnkey.js",
    "build:mac": "node build-app-turnkey.js mac",
    "build:win": "node build-app-turnkey.js win", 
    "build:linux": "node build-app-turnkey.js linux",
    "build:mac:x64": "node build-app-turnkey.js mac x64",
    "build:mac:arm64": "node build-app-turnkey.js mac arm64",
    "build:win:x64": "node build-app-turnkey.js win x64",
    "build:linux:x64": "node build-app-turnkey.js linux x64"
  },
  "build": {
    "appId": "com.theseusinsight.desktop",
    "productName": "Theseus Insight",
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "files": [
      "**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,readme.md,example,examples,**/test/**}",
      "!unused",
      "!python_runtime/**"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "app",
        "filter": [
          "theseus_insight/**",
          "theseus-ui/dist/**",
          "config/**",
          "data/**",
          "run_theseus_insight.py",
          "requirements.txt"
        ]
      },
      {
        "from": "python_runtime",
        "to": "app/python_runtime"
      },
      {
        "from": "env.template",
        "to": ".env"
      }
    ],
    "mac": {
      "icon": "icons/mac/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "category": "public.app-category.productivity",
      "identity": "Christian Merrill (4H8Z97B24M)",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "win": {
      "icon": "icons/win/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "icon": "icons/png",
      "category": "Office",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.11.0"
  }
}