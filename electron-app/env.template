# Theseus Insight Environment Configuration
# This file contains default/template values for environment variables
# Copy this to .env and modify the values as needed

# =============================================================================
# API CREDENTIALS
# =============================================================================

# OpenAI API Key (required for GPT models and TTS)
OPENAI_API_KEY=""

# Anthropic API Key (required for Claude models)  
ANTHROPIC_API_KEY=""

# Google API Key (required for Gemini models)
GOOGLE_API_KEY=""

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Gmail configuration for sending newsletters
GMAIL_SENDER_ADDRESS=""
GMAIL_APP_PASSWORD=""

# OAuth2 Configuration (for advanced email features)
CLIENT_ID=""
CLIENT_SECRET=""
PROJECT_ID=""

# =============================================================================
# LOCAL MODEL CONFIGURATION
# =============================================================================

# Ollama server URL (default for local installation)
OLLAMA_URL=http://localhost:11434

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database URL (default for embedded PostgreSQL)
DATABASE_URL=postgresql://theseus:theseus@localhost:55432/theseusdb

# =============================================================================
# APPLICATION SECURITY
# =============================================================================

# Secret key for encrypting sensitive data (CHANGE THIS IN PRODUCTION)
APP_SECRET_KEY=change-this-secret-key-in-production-to-something-secure

# =============================================================================
# EXTERNAL STORAGE (OPTIONAL)
# =============================================================================

# Uncomment and modify if you want to store data on an external drive
# EXTERNAL_DATA_PATH=/path/to/external/storage

# =============================================================================
# DEVELOPMENT/DEBUG OPTIONS
# =============================================================================

# Set to development for additional logging
NODE_ENV=production

# Docker networking (leave as true for most installations)
OLLAMA_PASSTHROUGH=true

# Media cleanup age in days
MEDIA_CLEANUP_AGE_DAYS=30 